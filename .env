BOT_TOKEN=your_bot_token_here
GUILD_ID=your_server_id_here
WALLPAPER_CHANNEL_ID=channel_id_for_wallpapers

# Cron schedule (default: every 6 hours)
# Examples:
# "0 */6 * * *" = Every 6 hours
# "0 */3 * * *" = Every 3 hours  
# "0 0 * * *"   = Once daily at midnight
# "*/30 * * * *" = Every 30 minutes
POST_INTERVAL=0 */6 * * *

# Categories: gaming, anime, cars, dark, aesthetic, nature, city, abstract, all
CATEGORY=all

# Optional: Get free API key at https://www.pexels.com/api/
API_KEY=your_pexels_api_key_here
