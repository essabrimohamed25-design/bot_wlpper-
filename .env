BOT_TOKEN=your_bot_token_here
GUILD_ID=your_server_id_here
WALLPAPER_CHANNEL_ID=channel_id_for_wallpapers

# Cron schedule (default: every 6 hours)
# "0 */6 * * *" = Every 6 hours
# "0 */3 * * *" = Every 3 hours
# "0 0 * * *" = Daily at midnight
# "*/30 * * * *" = Every 30 minutes
POST_INTERVAL=0 */6 * * *
